  "keyFeatures": [
    "Content Management - Posts, pages, categories, tags, and comments",
    "Plugin System - Extensible plugin architecture with lifecycle management",
    "Theme System - Customizable themes with template engine support",
    "Extension Framework - Kubernetes-style custom resource definitions",
    "User & Role Management - Authentication, authorization, and RBAC",
    "Media Library - Attachment management with various storage backends",
    "Search & Indexing - Full-text search with efficient indexing",
    "Notification System - Event-driven notification framework"
  ],
  "publicApiSurface": [
    "GET /apis/api.console.halo.run/v1alpha1/posts - List posts",
