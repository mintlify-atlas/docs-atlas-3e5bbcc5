    "POST /apis/api.console.halo.run/v1alpha1/themes - Install theme",
    "GET /apis/theme.halo.run/v1alpha1/themes - List installed themes",
    "GET /apis/content.halo.run/v1alpha1/posts/{name} - Get post by name",
    "POST /apis/api.halo.run/v1alpha1/comments - Create comment",
    "GET /apis/storage.halo.run/v1alpha1/attachments - List attachments",
